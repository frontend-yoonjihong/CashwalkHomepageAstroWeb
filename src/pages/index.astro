---

<Layout title="캐시워크 - 걸으면 돈이 되는 앱">
	<header class="bg-white border-b border-gray-200 sticky top-0 z-50">
		<div class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">
			<div class="flex items-center gap-8">
				<a href="/" class="flex items-center gap-2 group">
					<img 
						src="/logo.png" 
						alt="cashwalk" 
						class="h-10 w-auto"
					/>
				</a>
				
				<div class="relative hidden md:block w-96">
					<input 
						type="text" 
						id="main-search-input"
						placeholder="코스, 장소, 챌린지, 건강정보 검색" 
						class="w-full bg-gray-100 border-none rounded-full py-2 pl-4 pr-10 text-sm focus:ring-2 focus:ring-yellow-400 outline-none"
					/>
					<Search className="absolute right-3 top-2.5 w-4 h-4 text-gray-400" />
					
					<!-- Search Results Dropdown -->
					<div id="search-results" class="absolute top-full left-0 right-0 mt-2 bg-white rounded-2xl shadow-xl border border-gray-100 hidden z-[60] max-h-[400px] overflow-y-auto w-[calc(100vw-2rem)] md:w-96 -left-4 md:left-0">
						<div class="p-4">
							<div id="search-results-content" class="space-y-4">
								<!-- Results will be injected here -->
							</div>
							<div id="search-no-results" class="py-10 text-center hidden">
								<div class="text-4xl mb-2">🔍</div>
								<p class="text-sm text-gray-400">검색 결과가 없습니다.</p>
							</div>
						</div>
					</div>
				</div>
			</div>

			<div class="flex items-center gap-6 text-sm font-medium text-gray-600">
				<div class="hidden lg:flex items-center gap-2">
					<span class="text-xs text-gray-400">고객센터 비즈니스</span>
					<span class="text-xs text-gray-400">(캐시워크 for 비즈니스)</span>
				</div>
			</div>
		</div>
		
		<nav class="max-w-7xl mx-auto px-4 h-12 flex items-center gap-8 text-sm font-semibold border-t border-gray-50 overflow-x-auto whitespace-nowrap scrollbar-hide" id="main-nav">
			<button data-tab="home" class="nav-tab text-black border-b-2 border-black h-full flex items-center px-2 shrink-0">홈</button>
			<button data-tab="teamwork" class="nav-tab text-gray-500 hover:text-black h-full flex items-center px-2 shrink-0">팀워크</button>
			<button data-tab="walk" class="nav-tab text-gray-500 hover:text-black h-full flex items-center px-2 shrink-0">동네산책</button>
			<button data-tab="runmile" class="nav-tab text-gray-500 hover:text-black h-full flex items-center px-2 shrink-0">런마일</button>
			<button data-tab="challenge" class="nav-tab text-gray-500 hover:text-black h-full flex items-center px-2 shrink-0">모두의챌린지</button>
			<button data-tab="community" class="nav-tab text-gray-500 hover:text-black h-full flex items-center px-2 shrink-0">커뮤니티</button>
		</nav>
	</header>

	<main class="max-w-7xl mx-auto px-4 py-6">
		<!-- Tab Contents -->
		<div id="tab-contents">
			<!-- Home Tab -->
			<div id="content-home" class="tab-content grid grid-cols-1 lg:grid-cols-12 gap-6">
				<!-- Left Content -->
				<div class="lg:col-span-9 space-y-6">
					<!-- Hero Section -->
					<section id="hero-section" class="relative rounded-3xl overflow-hidden bg-[#1a1610] text-white p-6 md:p-12 min-h-[400px] md:min-h-[440px] flex flex-col justify-center border border-gray-800">
						<!-- Background Video -->
						<div id="hero-video-container" class="absolute inset-0 z-0">
							<video 
								autoplay 
								muted 
								loop 
								playsinline 
								class="w-full h-full object-cover opacity-60"
							>
								<source src="https://static.cashwalk.com/static/video/main-video-1680.mp4" type="video/mp4" />
							</video>
							<!-- Gradient Mask: Dark left to bright right -->
							<div class="absolute inset-0 bg-gradient-to-r from-[#1a1610] via-[#1a1610]/60 to-transparent"></div>
						</div>

						<!-- Logged Out Hero -->
						<div id="hero-logged-out" class="relative z-10 space-y-6 max-w-2xl">
							<div class="inline-flex items-center gap-2 px-3 py-1 bg-yellow-400/10 border border-yellow-400/20 rounded-full text-yellow-500 text-xs font-bold">
								<span class="w-1.5 h-1.5 bg-yellow-500 rounded-full animate-pulse"></span>
								국내 No.1 건강 리워드 앱
							</div>
							<h1 class="text-3xl md:text-5xl font-extrabold leading-[1.1] tracking-tight">
								걸으면 돈이 되는 앱,<br />
								<span class="text-yellow-400">캐시워크</span>
							</h1>
							<p class="text-gray-400 text-base md:text-lg font-medium leading-relaxed">
								걷기·러닝·챌린지로 캐시 적립하고<br />
								건강과 보상을 동시에 챙기세요
							</p>
							<div class="flex flex-wrap gap-3 md:gap-4 pt-2 md:pt-4">
								<button class="flex-1 md:flex-none bg-yellow-400 text-black px-6 md:px-8 py-3 md:py-4 rounded-2xl font-bold flex items-center justify-center gap-2 hover:bg-yellow-300 transition-all hover:scale-105 active:scale-95 shadow-lg shadow-yellow-400/20">
									<Download className="w-5 h-5" />
									앱 다운로드
								</button>
								<button class="flex-1 md:flex-none bg-white/5 backdrop-blur-md text-white border border-white/10 px-6 md:px-8 py-3 md:py-4 rounded-2xl font-bold hover:bg-white/10 transition-all hover:scale-105 active:scale-95">
									서비스 살펴보기
								</button>
							</div>
							
							<div class="grid grid-cols-2 md:flex md:gap-12 pt-6 md:pt-10 border-t border-white/5 gap-y-6">
								<div>
									<div class="text-xl md:text-2xl font-bold text-white">13조 2,000억+</div>
									<div class="text-[10px] text-gray-500 uppercase tracking-wider font-bold mt-1">2023년 누적 걸음수</div>
								</div>
								<div>
									<div class="text-xl md:text-2xl font-bold text-white">2,000만+</div>
									<div class="text-[10px] text-gray-500 uppercase tracking-wider font-bold mt-1">누적 회원수</div>
								</div>
								<div class="col-span-2 md:col-span-1">
									<div class="text-xl md:text-2xl font-bold text-white">157억 배</div>
									<div class="text-[10px] text-gray-500 uppercase tracking-wider font-bold mt-1">보행 기록 증가</div>
								</div>
							</div>
						</div>

						<!-- Logged In Hero -->
						<div id="hero-logged-in" class="hidden relative z-10 w-full">
							<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-12 items-center">
								<div class="space-y-4 md:space-y-6">
									<div class="inline-flex items-center gap-2 px-3 py-1 bg-green-400/10 border border-green-400/20 rounded-full text-green-500 text-xs font-bold">
										<span class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></span>
										오늘의 활동 분석
									</div>
									<h2 class="text-2xl md:text-4xl font-extrabold leading-tight">
										오늘 벌써 <span class="text-yellow-400">8,420걸음</span><br />
										정말 멋진 기록이에요!
									</h2>
									<p class="text-gray-400 text-sm md:text-lg">
										목표인 10,000걸음까지 <span class="text-white font-bold">1,580걸음</span> 남았습니다.<br />
										조금만 더 힘내세요!
									</p>
									<div class="flex gap-3 md:gap-4 pt-2">
										<div class="bg-white/5 border border-white/10 rounded-2xl p-3 md:p-4 flex-1">
											<div class="text-[10px] text-gray-500 font-bold uppercase mb-1">소모 칼로리</div>
											<div class="text-lg md:text-xl font-bold">342 kcal</div>
										</div>
										<div class="bg-white/5 border border-white/10 rounded-2xl p-3 md:p-4 flex-1">
											<div class="text-[10px] text-gray-500 font-bold uppercase mb-1">활동 시간</div>
											<div class="text-lg md:text-xl font-bold">64 min</div>
										</div>
									</div>
								</div>

								<div class="bg-white/5 backdrop-blur-md border border-white/10 rounded-[32px] md:rounded-[40px] p-6 md:p-8 space-y-6">
									<div class="flex items-center justify-between">
										<h3 class="font-bold text-sm md:text-base">주간 걸음 통계</h3>
										<span class="text-[10px] md:text-xs text-gray-500">최근 7일</span>
									</div>
									<div class="flex items-end justify-between h-32 md:h-48 gap-2 md:gap-3 px-1 md:px-2">
										<!-- 월 -->
										<div class="flex-1 flex flex-col items-center gap-3 group cursor-pointer">
											<div class="w-full bg-white/5 rounded-t-xl h-32 relative flex items-end overflow-hidden">
												<div class="w-full bg-yellow-400/40 group-hover:bg-yellow-400/60 transition-all duration-500 rounded-t-sm" style="height: 40%;"></div>
											</div>
											<span class="text-[10px] font-bold text-gray-500">월</span>
										</div>
										<!-- 화 -->
										<div class="flex-1 flex flex-col items-center gap-3 group cursor-pointer">
											<div class="w-full bg-white/5 rounded-t-xl h-32 relative flex items-end overflow-hidden">
												<div class="w-full bg-yellow-400/40 group-hover:bg-yellow-400/60 transition-all duration-500 rounded-t-sm" style="height: 70%;"></div>
											</div>
											<span class="text-[10px] font-bold text-gray-500">화</span>
										</div>
										<!-- 수 -->
										<div class="flex-1 flex flex-col items-center gap-3 group cursor-pointer">
											<div class="w-full bg-white/5 rounded-t-xl h-32 relative flex items-end overflow-hidden">
												<div class="w-full bg-yellow-400/40 group-hover:bg-yellow-400/60 transition-all duration-500 rounded-t-sm" style="height: 50%;"></div>
											</div>
											<span class="text-[10px] font-bold text-gray-500">수</span>
										</div>
										<!-- 목 -->
										<div class="flex-1 flex flex-col items-center gap-3 group cursor-pointer">
											<div class="w-full bg-white/5 rounded-t-xl h-32 relative flex items-end overflow-hidden">
												<div class="w-full bg-yellow-400/40 group-hover:bg-yellow-400/60 transition-all duration-500 rounded-t-sm" style="height: 85%;"></div>
											</div>
											<span class="text-[10px] font-bold text-gray-500">목</span>
										</div>
										<!-- 금 (오늘) -->
										<div class="flex-1 flex flex-col items-center gap-3 group cursor-pointer">
											<div class="w-full bg-yellow-400/10 rounded-t-xl h-32 relative flex items-end overflow-hidden border border-yellow-400/20">
												<div class="w-full bg-yellow-400 shadow-[0_0_15px_rgba(250,204,21,0.5)] transition-all duration-500 rounded-t-sm" style="height: 75%;"></div>
											</div>
											<span class="text-[10px] font-bold text-yellow-400">금</span>
										</div>
										<!-- 토 -->
										<div class="flex-1 flex flex-col items-center gap-3 group cursor-pointer">
											<div class="w-full bg-white/5 rounded-t-xl h-32 relative flex items-end overflow-hidden">
												<div class="w-full bg-yellow-400/20 group-hover:bg-yellow-400/40 transition-all duration-500 rounded-t-sm" style="height: 10%;"></div>
											</div>
											<span class="text-[10px] font-bold text-gray-500">토</span>
										</div>
										<!-- 일 -->
										<div class="flex-1 flex flex-col items-center gap-3 group cursor-pointer">
											<div class="w-full bg-white/5 rounded-t-xl h-32 relative flex items-end overflow-hidden">
												<div class="w-full bg-yellow-400/20 group-hover:bg-yellow-400/40 transition-all duration-500 rounded-t-sm" style="height: 5%;"></div>
											</div>
											<span class="text-[10px] font-bold text-gray-500">일</span>
										</div>
									</div>
								</div>
							</div>
						</div>
						
						<!-- Decorative elements -->
						<div class="absolute right-0 top-0 w-1/2 h-full bg-gradient-to-l from-yellow-400/5 to-transparent pointer-events-none"></div>
						<div class="absolute right-12 top-1/2 -translate-y-1/2 w-64 h-64 bg-yellow-400/10 blur-[120px] rounded-full"></div>
						<div class="absolute -right-10 -bottom-10 w-40 h-40 border border-white/5 rounded-full"></div>
						<div class="absolute right-20 bottom-20 w-20 h-20 border border-white/5 rounded-full"></div>
					</section>

					<!-- Services Grid -->
					<section class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-4">
						{services.map(service => (
							<a href={service.url} target={service.url !== '#' ? "_blank" : undefined} class="bg-white p-4 rounded-2xl border border-gray-100 hover:shadow-lg transition-all cursor-pointer group block">
								<div class={`w-12 h-12 ${service.color} rounded-xl flex items-center justify-center text-2xl mb-3 group-hover:scale-110 transition-transform`}>
									{service.icon}
								</div>
								<h3 class="font-bold text-sm mb-1">{service.name}</h3>
								<p class="text-[10px] text-gray-400 leading-tight">{service.desc}</p>
							</a>
						))}
					</section>

					<!-- Products Section -->
					<section class="space-y-4">
						<div class="flex items-center justify-between">
							<h2 class="text-xl font-bold flex items-center gap-2">
								오늘의 특가 상품 <span class="text-sm font-normal text-gray-400">(캐시딜)</span>
							</h2>
							<a href="https://cashdeal.kr/shop" target="_blank" class="text-sm text-gray-400 hover:text-black flex items-center gap-1">
								전체보기 <ChevronRight className="w-4 h-4" />
							</a>
						</div>
						<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
							{products.map(product => (
								<a href={product.url} target="_blank" class="bg-white rounded-3xl overflow-hidden border border-gray-100 hover:shadow-xl transition-all group cursor-pointer block">
									<div class="aspect-video bg-gray-50 flex items-center justify-center text-6xl group-hover:scale-105 transition-transform duration-500 overflow-hidden">
										{product.image.startsWith('http') ? (
											<img src={product.image} alt={product.name} class="w-full h-full object-cover" referrerPolicy="no-referrer" />
										) : (
											product.image
										)}
									</div>
									<div class="p-6 space-y-2">
										<h3 class="font-bold text-lg line-clamp-2 h-[3.5rem]">{product.name}</h3>
										<div class="flex items-center gap-2">
											<span class="text-red-500 font-bold text-xl">{product.discount}</span>

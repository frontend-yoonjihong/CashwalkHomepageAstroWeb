									<div class="text-[10px] text-gray-400">2026.04.13 15:12</div>
								</div>
							</div>
							<span class="text-sm font-bold text-blue-600">+15 C</span>
						</div>

						<div class="flex items-center justify-between p-4 hover:bg-gray-50 rounded-2xl transition-colors">
							<div class="flex items-center gap-3">
								<div class="w-10 h-10 bg-red-50 rounded-full flex items-center justify-center text-lg">☕</div>
								<div>
									<div class="text-sm font-bold">스타벅스 아메리카노 구매</div>
									<div class="text-[10px] text-gray-400">2026.04.12 18:45</div>
								</div>
							</div>
							<span class="text-sm font-bold text-red-600">-4,500 C</span>
						</div>

						<div class="flex items-center justify-between p-4 hover:bg-gray-50 rounded-2xl transition-colors">
							<div class="flex items-center gap-3">
								<div class="w-10 h-10 bg-green-50 rounded-full flex items-center justify-center text-lg">🏥</div>
								<div>
									<div class="text-sm font-bold">캐시닥 병원 방문 인증</div>
									<div class="text-[10px] text-gray-400">2026.04.11 11:20</div>
								</div>
							</div>
							<span class="text-sm font-bold text-blue-600">+500 C</span>
						</div>

						<div class="flex items-center justify-between p-4 hover:bg-gray-50 rounded-2xl transition-colors">
							<div class="flex items-center gap-3">
								<div class="w-10 h-10 bg-indigo-50 rounded-full flex items-center justify-center text-lg">🎮</div>
								<div>
									<div class="text-sm font-bold">5분게임 미션 완료</div>
									<div class="text-[10px] text-gray-400">2026.04.10 20:05</div>
								</div>
							</div>
							<span class="text-sm font-bold text-blue-600">+30 C</span>
						</div>
					</div>
				</div>
			</div>
			
			<div class="p-4 bg-gray-50 text-center">
				<p class="text-[10px] text-gray-400">캐시는 적립일로부터 1년간 유효합니다.</p>
			</div>
		</div>
	</div>

	<script>
		const tabs = document.querySelectorAll('.nav-tab');
		const contents = document.querySelectorAll('.tab-content');

		// Tab Switching Logic
		tabs.forEach(tab => {
			tab.addEventListener('click', () => {
				const target = tab.getAttribute('data-tab');

				tabs.forEach(t => {
					t.classList.remove('text-black', 'border-b-2', 'border-black');
					t.classList.add('text-gray-500');
				});
				tab.classList.add('text-black', 'border-b-2', 'border-black');
				tab.classList.remove('text-gray-500');

				contents.forEach(content => {
					content.classList.add('hidden');
				});
				document.getElementById(`content-${target}`)?.classList.remove('hidden');
			});
		});

		// Search Logic
		const searchInput = document.getElementById('main-search-input') as HTMLInputElement;
		const searchResults = document.getElementById('search-results');
		const searchResultsContent = document.getElementById('search-results-content');
		const searchNoResults = document.getElementById('search-no-results');

		const searchableData = [
			{ type: '서비스', items: [
				{ name: '캐시닥', desc: '병원찾기, 병원이벤트' },
				{ name: '지니어트', desc: '다이어트, 식단관리' },
				{ name: '트로스트', desc: '심리상담, 명상' },
				{ name: '언니의파우치', desc: '뷰티 리뷰' },
				{ name: '과민보스', desc: '건강 관리' }
			]},
			{ type: '상품', items: [
				{ name: '건강식 샐러드', desc: '신선한 채소 구독' },
				{ name: '비타민D', desc: '필수 영양제' },
				{ name: '워킹화', desc: '편안한 운동화' }
			]},
			{ type: '친구', items: [
				{ name: '헤일리', desc: '친구' },
				{ name: '걷기왕', desc: '친구' },
				{ name: '캐시부자', desc: '친구' }
			]}
		];

		searchInput?.addEventListener('input', (e) => {
			const query = (e.target as HTMLInputElement).value.trim().toLowerCase();
			
			if (!query) {
				searchResults?.classList.add('hidden');
				return;
			}

			let hasResults = false;
			if (searchResultsContent) {
				searchResultsContent.innerHTML = '';
				
				searchableData.forEach(category => {
					const filteredItems = category.items.filter(item => 
						item.name.toLowerCase().includes(query) || 
						item.desc.toLowerCase().includes(query)
					);

					if (filteredItems.length > 0) {
						hasResults = true;
						const categoryHtml = `
							<div>
								<div class="text-[10px] font-bold text-gray-400 uppercase mb-2 px-1">${category.type}</div>
								<div class="space-y-1">
									${filteredItems.map(item => `
										<div class="p-2 hover:bg-gray-50 rounded-xl cursor-pointer flex items-center justify-between group">
											<div>
												<div class="text-sm font-bold group-hover:text-yellow-600">${item.name}</div>
												<div class="text-[10px] text-gray-400">${item.desc}</div>
											</div>
											<ChevronRight class="w-3 h-3 text-gray-300" />
										</div>
									`).join('')}
								</div>
							</div>
						`;
						searchResultsContent.innerHTML += categoryHtml;
					}
				});

				if (hasResults) {
					searchResults?.classList.remove('hidden');
					searchNoResults?.classList.add('hidden');
				} else {
					searchResults?.classList.remove('hidden');
					searchNoResults?.classList.remove('hidden');
				}
			}
		});

		// Close search results when clicking outside
		document.addEventListener('click', (e) => {
			if (!searchInput?.contains(e.target as Node) && !searchResults?.contains(e.target as Node)) {
				searchResults?.classList.add('hidden');
			}
		});

		// Cash History Modal Logic
		const myCashBtn = document.getElementById('my-cash-btn');
		const cashHistoryModal = document.getElementById('cash-history-modal');
		const closeCashHistory = document.getElementById('close-cash-history');

		myCashBtn?.addEventListener('click', () => {
			cashHistoryModal?.classList.remove('hidden');
			document.body.style.overflow = 'hidden';
		});

		closeCashHistory?.addEventListener('click', () => {
			cashHistoryModal?.classList.add('hidden');
			document.body.style.overflow = '';
		});

		cashHistoryModal?.addEventListener('click', (e) => {
			if (e.target === cashHistoryModal.querySelector('.absolute.inset-0')) {
				cashHistoryModal?.classList.add('hidden');
				document.body.style.overflow = '';
			}
		});

		// Cashtalk Tab Logic
		const cashtalkTabs = document.querySelectorAll('.cashtalk-tab');
		const cashtalkPanels = document.querySelectorAll('.cashtalk-panel');
		const chatItems = document.querySelectorAll('#cashtalk-content-chat > div');
		const chatRoomPanel = document.getElementById('cashtalk-content-chatroom');
		const chatBackBtn = document.getElementById('chat-back-btn');
		const chatRoomName = document.getElementById('chat-room-name');
		const chatMessagesContainer = document.getElementById('chat-messages-container');

		const randomMessages = [
			"안녕하세요! 오늘 날씨가 참 좋네요. ☀️",
			"캐시워크로 오늘 벌써 5천보 걸었어요! 🏃‍♂️",
			"혹시 추천 코드 공유 가능하신가요? 🙏",
			"행운 캐시 보내드렸습니다~ 확인해보세요! 💰",
			"오늘 챌린지 같이 하실 분 구해요. 🏆",
			"와, 벌써 만보 넘으셨네요! 대단해요. 👍",
			"점심 맛있게 드셨나요? 🍱",
			"내일도 같이 열심히 걸어봐요! 🔥",
			"캐시워크 덕분에 운동하는 습관이 생겼어요. 😊",
			"팀워크 챌린지 보상 들어왔네요 ㅎㅎ 🎁",
			"오늘도 건강한 하루 되세요! ✨",
			"걸음 수 채우기 힘들지만 뿌듯하네요. 💦"
		];

		const openChatRoom = (name: string) => {
			if (chatRoomName) chatRoomName.innerText = name;
			if (chatRoomPanel) chatRoomPanel.classList.remove('hidden');
			
			// Generate random messages
			if (chatMessagesContainer) {
				chatMessagesContainer.innerHTML = '';
				const msgCount = 5 + Math.floor(Math.random() * 5);
				for (let i = 0; i < msgCount; i++) {
					const isMe = Math.random() > 0.6;
					const msg = randomMessages[Math.floor(Math.random() * randomMessages.length)];
					const time = `${Math.floor(Math.random() * 12) + 1}:${Math.floor(Math.random() * 60).toString().padStart(2, '0')}`;
					
					const msgHtml = `
						<div class="flex ${isMe ? 'justify-end' : 'justify-start'} gap-2">
							${!isMe ? `<div class="w-8 h-8 bg-gray-300 rounded-xl flex items-center justify-center text-xs font-bold">${name[0]}</div>` : ''}
							<div class="flex flex-col ${isMe ? 'items-end' : 'items-start'} max-w-[70%]">
								${!isMe ? `<span class="text-[10px] text-gray-500 mb-1 ml-1">${name}</span>` : ''}
								<div class="flex items-end gap-1 ${isMe ? 'flex-row-reverse' : 'flex-row'}">
									<div class="${isMe ? 'bg-yellow-400 text-black' : 'bg-white text-black'} p-2 rounded-xl text-xs shadow-sm">
										${msg}
									</div>
									<span class="text-[8px] text-gray-500 mb-0.5">${time}</span>
								</div>
							</div>
						</div>
					`;
					chatMessagesContainer.innerHTML += msgHtml;
				}
				// Scroll to bottom
				chatMessagesContainer.scrollTop = chatMessagesContainer.scrollHeight;
			}
		};

		cashtalkTabs.forEach(tab => {
			tab.addEventListener('click', () => {
				const target = tab.id.replace('cashtalk-tab-', '');

				cashtalkTabs.forEach(t => {
					t.classList.remove('text-yellow-500', 'border-b-2', 'border-yellow-500');
					t.classList.add('text-gray-400');
				});
				tab.classList.add('text-yellow-500', 'border-b-2', 'border-yellow-500');
				tab.classList.remove('text-gray-400');

				cashtalkPanels.forEach(panel => {
					panel.classList.add('hidden');
				});
				document.getElementById(`cashtalk-content-${target}`)?.classList.remove('hidden');
			});
		});

		chatItems.forEach(item => {
			item.addEventListener('click', () => {
				const name = item.querySelector('h4')?.innerText || '채팅방';
				openChatRoom(name);
			});
		});

		chatBackBtn?.addEventListener('click', () => {
			if (chatRoomPanel) chatRoomPanel.classList.add('hidden');
		});

		// Lucky Cash Toast Logic
		const showToast = (message: string) => {
			const toast = document.createElement('div');
			toast.className = 'fixed bottom-8 left-1/2 -translate-x-1/2 bg-black/80 text-white px-6 py-3 rounded-full text-sm font-bold z-[100] transition-all duration-300 opacity-0 translate-y-4';
			toast.innerText = message;
			document.body.appendChild(toast);
			
			// Animate in
			setTimeout(() => {
				toast.classList.remove('opacity-0', 'translate-y-4');
			}, 10);
			
			// Animate out and remove
			setTimeout(() => {
				toast.classList.add('opacity-0', 'translate-y-4');
				setTimeout(() => {
					document.body.removeChild(toast);
				}, 300);
			}, 3000);
		};

		const luckyCashBtns = document.querySelectorAll('#cashtalk-content-friends button');
		luckyCashBtns.forEach(btn => {
			btn.addEventListener('click', (e) => {
				const target = e.currentTarget as HTMLButtonElement;
				const originalText = target.innerText;
				
				target.disabled = true;
				target.innerText = '보내는 중...';
				target.classList.add('opacity-50');
				
				setTimeout(() => {
					showToast('🍀 행운 캐시를 보냈습니다!');
					target.remove();
				}, 1500);
			});
		});

		// Auth Logic
		const loginBtn = document.getElementById('login-btn');
		const logoutBtn = document.getElementById('logout-btn');
		const cashtalkSidebar = document.getElementById('cashtalk-sidebar');
		const loggedOutView = document.getElementById('logged-out-view');
		const loggedInView = document.getElementById('logged-in-view');
		const heroLoggedOut = document.getElementById('hero-logged-out');
		const heroLoggedIn = document.getElementById('hero-logged-in');
		const heroVideoContainer = document.getElementById('hero-video-container');

		const setLoginState = (isLoggedIn: boolean) => {
			if (isLoggedIn) {
				loggedOutView?.classList.add('hidden');
				loggedInView?.classList.remove('hidden');
				cashtalkSidebar?.classList.remove('hidden');
				heroLoggedOut?.classList.add('hidden');
				heroLoggedIn?.classList.remove('hidden');
				heroVideoContainer?.classList.add('hidden');
				
				// Default to Chat tab on login
				const chatTab = document.getElementById('cashtalk-tab-chat');
				if (chatTab) chatTab.click();
			} else {
				loggedOutView?.classList.remove('hidden');
				loggedInView?.classList.add('hidden');
				cashtalkSidebar?.classList.add('hidden');
				heroLoggedOut?.classList.remove('hidden');
				heroLoggedIn?.classList.add('hidden');
				heroVideoContainer?.classList.remove('hidden');
			}
		};

		loginBtn?.addEventListener('click', () => {
			const originalContent = loginBtn.innerHTML;
			loginBtn.disabled = true;
			loginBtn.innerHTML = `
				<svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
					<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
					<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
				</svg>
				<span>로그인 중...</span>
			`;
			loginBtn.classList.add('opacity-80', 'cursor-not-allowed');

			// Simulate login with 2.5s delay
			setTimeout(() => {
				setLoginState(true);
				// Reset button for next time (though it will be hidden)
				loginBtn.disabled = false;
				loginBtn.innerHTML = originalContent;
				loginBtn.classList.remove('opacity-80', 'cursor-not-allowed');
			}, 2500);
		});

		logoutBtn?.addEventListener('click', () => {
			// Simulate logout
			setLoginState(false);
		});
	</script>

	<footer class="bg-[#2a2a2a] text-gray-400 py-12 mt-12">
		<div class="max-w-7xl mx-auto px-4">
			<div class="mb-8">
				<img 
					src="/logo-white.png" 
					alt="cashwalk" 
					class="h-8 w-auto"
				/>
			</div>
			
			<div class="flex flex-wrap gap-6 text-sm mb-8">
				<a href="#" class="text-white font-bold">회사소개</a>
				<a href="#" class="hover:text-white">인재채용</a>
				<a href="https://static.cashwalk.com/privacy/service.html" target="_blank" class="hover:text-white">이용약관</a>
				<a href="https://static.cashwalk.com/privacy/privacy.html" target="_blank" class="hover:text-white">개인정보처리방침</a>
				<a href="#" class="hover:text-white">광고 소개</a>
				<a href="#" class="hover:text-white">IR / PR</a>
				<a href="#" class="hover:text-white">고객센터</a>
				<a href="#" class="hover:text-white">캐시워크 for 비즈니스</a>
			</div>
			
			<div class="text-xs space-y-1">
				<p>© 2025 CASHWALK Inc. | cashwalk.com</p>
			</div>
		</div>
	</footer>
</Layout>

